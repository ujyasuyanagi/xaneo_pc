# ─── Flutter / Dart ───────────────────────────────────────
# Папка сборки Flutter
build/

# Dart tool кэш (содержит .dill по 60+ МБ)
.dart_tool/

# Pub кэш пакетов
.pub-cache/
.pub/

# Генерируемые файлы локализации
lib/l10n/

# ─── Linux-специфичное ────────────────────────────────────
# Скачанный движок Flutter (ephemeral)
linux/flutter/ephemeral/

# ─── Собранные пакеты и артефакты ───────────────────────
# Готовые дистрибутивы — они создаются в CI/CD
dist/

# AppDir — временная директория для сборки AppImage
AppDir/lib/
AppDir/data/
# (AppDir/AppRun, AppDir/*.desktop, AppDir/*.png — полезно держать)

# Сторонний инструмент appimagetool (качается при необходимости)
appimagetool-x86_64.AppImage

# ─── IDE / Редакторы ──────────────────────────────────────
.vscode/
.idea/
*.iml
*.ipr
*.iws
.fleet/

# ─── OS-мусор ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo

# ─── Логи ─────────────────────────────────────────────────
*.log
*.pid

# ─── Переменные окружения ─────────────────────────────────
.env
.env.local
.env.*.local
